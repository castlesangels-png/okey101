import 'package:flutter/material.dart';

class GameTileWidget extends StatelessWidget {
  final String value;
  final Color color;
  final bool isJoker;
  final bool isFakeOkey;
  final double width;
  final double height;

  const GameTileWidget({
    super.key,
    required this.value,
    required this.color,
    this.isJoker = false,
    this.isFakeOkey = false,
    this.width = 42,
    this.height = 62,
  });

  @override
  Widget build(BuildContext context) {
    final isFaceDownLike = isJoker || isFakeOkey;

    return Container(
      width: width,
      height: height,
      margin: const EdgeInsets.symmetric(horizontal: 2, vertical: 2),
      decoration: BoxDecoration(
        color: isFaceDownLike ? Colors.white : Colors.white,
        borderRadius: BorderRadius.circular(8),
        border: Border.all(
          color: isFaceDownLike ? Colors.grey.shade400 : Colors.black12,
          width: isFaceDownLike ? 2 : 1,
        ),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.06),
            blurRadius: 6,
            offset: const Offset(0, 2),
          ),
        ],
      ),
      child: Center(
        child: isFaceDownLike
            ? Container(
                width: width * 0.58,
                height: height * 0.68,
                decoration: BoxDecoration(
                  color: Colors.grey.shade200,
                  borderRadius: BorderRadius.circular(6),
                  border: Border.all(color: Colors.grey.shade400),
                ),
                child: Center(
                  child: Icon(
                    isFakeOkey ? Icons.auto_awesome : Icons.style,
                    color: Colors.grey.shade600,
                    size: 18,
                  ),
                ),
              )
            : Text(
                value,
                style: TextStyle(
                  color: color,
                  fontWeight: FontWeight.bold,
                  fontSize: 17,
                ),
              ),
      ),
    );
  }
}
